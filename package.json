{
  "name": "deyana",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "core:install": "python -m venv services/core/.venv && services\\core\\.venv\\Scripts\\python.exe -m pip install -e \"services/core[dev]\"",
    "core:dev": "services\\core\\.venv\\Scripts\\python.exe -m deyana_core",
    "core:test": "services\\core\\.venv\\Scripts\\python.exe -m pytest services/core/tests",
    "dev": "pnpm --filter @deyana/desktop dev",
    "desktop:dev": "pnpm --filter @deyana/desktop tauri dev",
    "desktop:build": "pnpm --filter @deyana/desktop tauri build"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  }
}
